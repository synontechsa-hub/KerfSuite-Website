# Supabase Configuration
# IMPORTANT: Copy this file to .env.local and replace with your actual project values
# You can find these in your Supabase Dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# SECRET: Keep this safe! Required for administrative actions like inviting users.
# Use this ONLY in server-side code (never prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Public domain for KerfSuite
NEXT_PUBLIC_SITE_URL=https://kerfsuite.vercel.app/

# Security secret for automated provisioning API (/api/provision)
# Generate a long random string for this
PROVISIONING_SECRET=your_provisioning_secret_here

# Rate limiting with Upstash
# Signed in as [email address here]
UPSTASH_REDIS_REST_URL=[redacted]
UPSTASH_REDIS_REST_TOKEN=[redacted]

# Sentry Error tracking
# Signed in as [email address here] (GitHub)
SENTRY_DSN=[redacted]
SENTRY_AUTH_TOKEN=[redacted]
SENTRY_VERCEL_DRAINS=[redacted]